{
  "name": "coderoom",
  "version": "0.1.0",
  "private": true,
  "description": "CodeRoom monorepo for the Kodex Mini Hack-Sprint.",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm --prefix api run dev",
    "dev:web": "npm --prefix web run dev",
    "start": "npm --prefix api start",
    "build": "npm --prefix web run build",
    "install:all": "npm install && npm --prefix api install && npm --prefix web install",
    "lint": "npm --prefix web run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
